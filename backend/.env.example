# Example environment for the Marketing Report Automation backend.
# Copy to `.env` and fill real values. `.env` is gitignored — never commit secrets.

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=marketing_report

# --- Seed admin (created on startup / via `python -m app.scripts.seed`) ---
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me

# --- Session cookie signing secret (httpOnly auth) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# --- Email / SMTP (Mailjet relay) ---
# Empty SMTP_HOST  -> dev-log fallback: emails (incl. OTP) are printed to the
#                     server console, no mail server required.
# Mailjet relay    -> set all of the below. Get the API Key (username) and
#                     Secret Key (password) from Mailjet:
#                       Account settings -> SMTP and SEND API settings.
#
#   Server : in-v3.mailjet.com
#   Port   : 587 + SMTP_STARTTLS=true            (recommended)
#            465 + SMTP_SSL=true                  (implicit TLS fallback)
#            25 / 2525 + SMTP_STARTTLS=true       (if 587 is blocked)
#   User   : Mailjet API Key   (public key)
#   Pass   : Mailjet Secret Key (private key)
#   From   : a Mailjet-VALIDATED sender address / authenticated domain (SPF+DKIM),
#            otherwise Mailjet rejects the message.
SMTP_HOST=
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@yourvalidateddomain.com
APP_NAME=JSW Marketing Reports
APP_BASE_URL=http://localhost:5173
